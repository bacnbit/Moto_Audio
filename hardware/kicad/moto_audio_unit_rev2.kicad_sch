  ;; USB-C VBUS → IP5306 VIN
  (wire (pts (xy 37.62 42.38) (xy 10 42.38)))
  (wire (pts (xy 10 42.38) (xy 10 72.38)))
  (wire (pts (xy 10 72.38) (xy 119.84 72.38)))

  ;; USB-C VBUS → VBUS_CHGPASS (passthrough to battery pogo)
  (wire (pts (xy 37.62 42.38) (xy 50 42.38)))
  (wire (pts (xy 50 42.38) (xy 50 257.46)))
  (wire (pts (xy 50 257.46) (xy 22.38 257.46)))

  ;; Battery pogo BAT+ → TPS2116 IN1
  (wire (pts (xy 37.62 255.08) (xy 100 255.08)))
  (wire (pts (xy 100 255.08) (xy 100 144.92)))
  (wire (pts (xy 100 144.92) (xy 119.84 144.92)))

  ;; Keep-alive JST BAT+ → TPS2116 IN2
  (wire (pts (xy 37.62 327.46) (xy 95 327.46)))
  (wire (pts (xy 95 327.46) (xy 95 147.46)))
  (wire (pts (xy 95 147.46) (xy 119.84 147.46)))

  ;; TPS2116 VOUT → IP5306 BAT+ (muxed battery to boost)
  (wire (pts (xy 140.16 144.92) (xy 155 144.92)))
  (wire (pts (xy 155 144.92) (xy 155 67.46)))
  (wire (pts (xy 155 67.46) (xy 140.16 67.46)))

  ;; IP5306 VOUT_5V → +5V rail
  (wire (pts (xy 140.16 72.38) (xy 165 72.38)))
  (wire (pts (xy 165 72.38) (xy 165 15)))

  ;; +5V → AMS1117 VIN
  (wire (pts (xy 165 15) (xy 165 210)))
  (wire (pts (xy 165 210) (xy 137.62 210)))

  ;; AMS1117 VOUT → +3V3 rail
  (wire (pts (xy 122.38 210) (xy 108 210)))
  (wire (pts (xy 108 210) (xy 108 15)))

  ;; USB-C VIN → MCP73831 VDD (keep-alive charger gets 5V from USB)
  (wire (pts (xy 165 15) (xy 165 264.92)))
  (wire (pts (xy 165 264.92) (xy 137.62 264.92)))

  ;; MCP73831 VBAT → Keep-alive JST BAT+
  (wire (pts (xy 122.38 267.46) (xy 60 267.46)))
  (wire (pts (xy 60 267.46) (xy 37.62 327.46)))

  ;; DAC LOUT/ROUT → TPA6132 INL/INR (AMP_L/AMP_R net labels handle routing)
  ;; I2S BCK/WS/DOUT → PCM5102 BCK/LRCK/DIN (I2S net labels handle)
  ;; UART0/1 → BM62 A/B (UART net labels handle)

  ;; TPA6132 OUTL → J2 IEM_L
  (wire (pts (xy 440.16 324.92) (xy 480 324.92)))
  (wire (pts (xy 480 324.92) (xy 480 322.38)))
  (wire (pts (xy 480 322.38) (xy 532.38 322.38)))

  ;; TPA6132 OUTR → J2 IEM_R
  (wire (pts (xy 440.16 327.46) (xy 483 327.46)))
  (wire (pts (xy 483 327.46) (xy 483 324.92)))
  (wire (pts (xy 483 324.92) (xy 532.38 324.92)))

  ;; MIC1 DATA → J6 MIC_DATA pigtail
  (wire (pts (xy 547.62 260) (xy 560 260)))
  (wire (pts (xy 560 260) (xy 560 197.46)))
  (wire (pts (xy 560 197.46) (xy 547.62 197.46)))

  ;; J6 pigtail MIC_DATA → ESP32 I2S_DIN (via net label)
  ;; J2 MIC_P/N ← from pigtail cable (user wires in helmet)

  ;; ════════════════════════════════════════════════════════════════
  ;; DESIGN NOTES (as text items on schematic)
  ;; ════════════════════════════════════════════════════════════════

  (text "BT RADIO #1: ESP32-S3 native BT Classic\nPairs to phone via A2DP (music) + HFP (calls/nav)"
    (at 240 420 0) (effects (font (size 1.27 1.27)) (justify left)))

  (text "BT RADIO #2: BM62 (U2)\nPairs to UV-PRO or any HFP radio\nUART0 controlled by ESP32"
    (at 380 420 0) (effects (font (size 1.27 1.27)) (justify left)))

  (text "BT RADIO #3: BM62 (U3)\nExpansion: BS-PTT direct / intercom / 2nd phone\nUART1 controlled by ESP32"
    (at 380 440 0) (effects (font (size 1.27 1.27)) (justify left)))

  (text "WIRED RADIO: J3 TRRS 3.5mm\nTip=SPK_IN Ring1=MIC_OUT Ring2=PTT Slv=GND\nK1 adapter cable = native BTECH/Baofeng/Kenwood"
    (at 20 440 0) (effects (font (size 1.27 1.27)) (justify left)))

  (text "HOT-SWAP: TPS2116 <1us switchover\nMain pack (J4 pogo) preferred, keep-alive (J5) fallback\nBT connections survive pack swap"
    (at 80 460 0) (effects (font (size 1.27 1.27)) (justify left)))

  (text "ALL SERVICEABILITY:\nJ5=JST-PH2 keep-alive cell (user replaceable)\nJ6=JST-GH2 mic pigtail\nSW1=socketed EC11\nJ4=pogo contacts on daughterboard header"
    (at 80 480 0) (effects (font (size 1.27 1.27)) (justify left)))

  (text "BATTERY PACKS (separate PCB):\nSkim=1x LP805060 2000mAh ~7hr\nStandard=2x LP805060 4000mAh ~14hr\nChonker=4x LP805060 8000mAh ~28hr\nEach pack: BQ25895 fast charge IC + USB-C + NTC"
    (at 380 460 0) (effects (font (size 1.27 1.27)) (justify left)))

  ;; ════════════════════════════════════════════════════════════════
  ;; SHEET INSTANCES
  ;; ════════════════════════════════════════════════════════════════

  (sheet_instances
    (path "/" (page "1"))
  )

